# rustydns systemd service unit
# Install: cp install/rustydns.service /etc/systemd/system/
# Enable: systemctl daemon-reload && systemctl enable --now rustydns

[Unit]
Description=rustydns — mesh-native DNS resolver and ad-blocker
Documentation=https://github.com/Iwan-Teague/rustydns
After=network-online.target
Wants=network-online.target
# Start after rustynet if present on the same host
After=rustynet.service
PartOf=rustynet.service

[Service]
Type=simple
User=rustydns
Group=rustydns

ExecStart=/usr/local/bin/rustydnsd --config /etc/rustydns/rustydns.toml
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s

# ---------------------------------------------------------------------------
# Privilege hardening
# Bind port 53/853 via ambient capability, then drop everything else.
# ---------------------------------------------------------------------------
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

# ---------------------------------------------------------------------------
# Filesystem restrictions
# ---------------------------------------------------------------------------
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ReadOnlyPaths=/
ReadWritePaths=/var/lib/rustydns

# Allow read access to the rustynet control database.
ReadOnlyPaths=/var/lib/rustynet/control.db

# ---------------------------------------------------------------------------
# Network restrictions — only DNS and HTTPS sockets allowed
# ---------------------------------------------------------------------------
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

# ---------------------------------------------------------------------------
# Kernel hardening
# ---------------------------------------------------------------------------
RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallFilter=@system-service
SystemCallArchitectures=native
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectClock=true
ProtectControlGroups=true
ProtectHostname=true

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rustydnsd

[Install]
WantedBy=multi-user.target
